{
  // Lint scope: hand-authored files only.
  //
  // examples/ is generated content (scripts/gen-site.mjs and
  // tools/diff-pair-generator.py). No one hand-edits it and any manual
  // fix would be overwritten on the next generation run. Linting it would
  // be meaningless noise. This is an intentional exclusion of generated
  // output, not a numbers-reduction shortcut.
  //
  // docs/internal/ was already excluded by the CI command before this config
  // existed. docs/superpowers/ is the same class of document (internal
  // governance: specs and plans that predate the lint gate). Both directories
  // group under docs/, which REPOSITORY.md describes as "governance only, not
  // built by Astro." The original CI command excluded docs/internal/ but not
  // docs/superpowers/ by oversight; this config makes the exclusion explicit
  // and symmetric.
  //
  // _LOCAL/, _local/, .memsearch/, .superpowers/, _agent-context/ are
  // gitignored local research / tooling directories; they do not exist in CI.
  // site/src/content/docs/reference|examples|recipes|templates are generated
  // by scripts/gen-site.mjs (gitignored) and only present after a local build.
  "globs": ["**/*.md"],
  "ignores": [
    "node_modules/**",
    "site/node_modules/**",
    "_LOCAL/**",
    "_local/**",
    "docs/internal/**",
    "docs/superpowers/**",
    "examples/**",
    "_agent-context/**",
    ".memsearch/**",
    ".superpowers/**",
    "site/src/content/docs/reference/**",
    "site/src/content/docs/examples/**",
    "site/src/content/docs/recipes/**",
    "site/src/content/docs/templates/**"
  ],
  "config": {
    "default": true,

    // MD013: Line length (default 80 chars).
    // This repo writes long prose lines deliberately. Taxonomy ENTRY.md files
    // routinely run 200-500 characters per line in description blocks,
    // language_patterns lists, and llm_instruction_phrasing sections. Wrapping
    // those at 80 chars would produce fragmented, hard-to-read copy. The
    // rule also fires inside YAML frontmatter blocks where line length is
    // meaningless. Disabling is the only practical option given that
    // 1,041 of 1,041 errors in taxonomy/ are MD013.
    "MD013": false,

    // MD024: No duplicate headings.
    // CHANGELOG.md uses repeated subsection names (Added, Changed, Fixed,
    // Security) under each version heading - this is the Keep a Changelog
    // convention and cannot be changed. With siblings_only: true, the rule
    // only flags headings that are siblings under the same parent, which is
    // the correct semantic check. Headings with identical text under
    // different version sections pass cleanly.
    "MD024": { "siblings_only": true },

    // MD033: No inline HTML.
    // README.md uses HTML intentionally: an <h1 align="center"> title,
    // badge <img> elements wrapped in <a> links, and <p align="center">
    // blocks. This is the established GitHub-rendered-README pattern; the
    // HTML is the intended display layer, not incidental markup.
    "MD033": false,

    // MD040: Fenced code block language.
    // Format ENTRY.md files (all 52 format entries) contain a "Canonical
    // template" fenced code block whose content is a markdown structure
    // template, not runnable code. Adding a language tag (markdown) would
    // be technically correct but adds zero functional value for the reader.
    // More importantly, conforming requires touching 72 files for a cosmetic
    // annotation, which exceeds the repo's threshold for mass-file changes
    // on a non-content edit. Disabling is the appropriate scoped decision.
    "MD040": false,

    // MD041: First line should be a top-level heading.
    // All taxonomy ENTRY.md files begin with YAML frontmatter (---), so
    // the first rendered line is always an H2 (the entry name in the body).
    // The H2 is correct per the entry schema - the frontmatter `name` field
    // carries the H1-equivalent identity and H1 in the body would duplicate
    // it. README.md starts with an <a id="readme-top"> HTML anchor (not a
    // heading), which is the established back-to-top pattern.
    // .github/pull_request_template.md starts with ## because it is a body
    // fragment, not a standalone document.
    "MD041": false
  }
}
